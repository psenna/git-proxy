# Copy to `.env` (gitignored) and fill in. docker compose reads this automatically.

# Ollama Cloud API key — create one at https://ollama.com/settings/keys.
# Sent to Ollama as the Bearer (ANTHROPIC_AUTH_TOKEN). Never baked into the image.
OLLAMA_API_KEY=your_ollama_cloud_api_key

# Ollama Cloud model Claude Code should use (plain name; the cloud API is hit
# directly, so no `-cloud` suffix). Defaults to gpt-oss:120b if unset.
# Note: qwen3-coder has stronger tool-calling fidelity for agentic git work.
OLLAMA_MODEL=gpt-oss:120b

# Agent Bearer presented to git-proxy. MUST match auth.tokens in config.yaml
# (default config maps "agent-token-1" -> "claude-code-agent"). The proxy consumes
# this for auth only; it is never forwarded to GitHub.
AGENT_TOKEN=agent-token-1

# owner/repo.git the agent will clone + open PRs against. Must match the key in
# credentials.yaml (replace its OWNER/REPO.git too).
GITHUB_REPO=psenna/git-proxy.git